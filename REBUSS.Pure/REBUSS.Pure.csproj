<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyTitle>REBUSS.Pure</AssemblyTitle>
    <AssemblyName>REBUSS.Pure</AssemblyName>
    <ApplicationIcon>..\REBUSS.Pure.ico</ApplicationIcon>

    <!-- .NET Tool packaging -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>rebuss-pure</ToolCommandName>
    <PackageId>CodeReview.MCP</PackageId>
    <Version>0.6.0</Version>
    <Authors>Michał Korbecki</Authors>
    <Description>Lightweight MCP server for AI-assisted pull request analysis. Supports Azure DevOps and GitHub.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/rebuss/CodeReview.MCP</PackageProjectUrl>
    <RepositoryUrl>https://github.com/rebuss/CodeReview.MCP</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>mcp;azure-devops;github;pull-request;code-review;copilot;dotnet-tool;ai</PackageTags>
    <RollForward>Major</RollForward>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Cli\Prompts\review-pr.prompt.md" />
    <EmbeddedResource Include="Cli\Prompts\self-review.prompt.md" />
    <EmbeddedResource Include="Cli\Prompts\create-pr.md" />
    <!-- Feature 024 — Claude Code skills shipped via init alongside Copilot prompts.
         LogicalName explicit because the directory name contains a hyphen and the
         default resource path resolver replaces hyphens with underscores, making the
         resource lookup fragile. With LogicalName the lookup is deterministic. -->
    <EmbeddedResource Include="Cli\Skills\review-pr\SKILL.md"
                      LogicalName="REBUSS.Pure.Cli.Skills.review-pr.SKILL.md" />
    <EmbeddedResource Include="Cli\Skills\self-review\SKILL.md"
                      LogicalName="REBUSS.Pure.Cli.Skills.self-review.SKILL.md" />
    <EmbeddedResource Include="Services\CopilotReview\Prompts\copilot-page-review.md" />
    <EmbeddedResource Include="Services\CopilotReview\Prompts\copilot-finding-validation.md" />
    <EmbeddedResource Update="Properties\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Properties\Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="REBUSS.Pure.Tests" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="GitHub.Copilot.SDK" Version="0.2.2" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.5" />
    <PackageReference Include="ModelContextProtocol" Version="1.2.0" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\REBUSS.Pure.Core\REBUSS.Pure.Core.csproj" />
    <ProjectReference Include="..\REBUSS.Pure.AzureDevOps\REBUSS.Pure.AzureDevOps.csproj" />
    <ProjectReference Include="..\REBUSS.Pure.GitHub\REBUSS.Pure.GitHub.csproj" />
    <ProjectReference Include="..\REBUSS.Pure.RoslynProcessor\REBUSS.Pure.RoslynProcessor.csproj" />
  </ItemGroup>

  <!-- Multi-RID Copilot CLI bundling: only runs when CopilotBundleAllRids=true (set by CI during pack). -->
  <Import Project="Build\BundleCopilotCliAllRids.targets" />

</Project>
